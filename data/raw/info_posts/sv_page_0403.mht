.contentVote { position: relative; display: flex; flex-direction: column; align-items: center; min-width: 1.41em; color: rgb(175, 175, 175); font-size: 1.5625rem; }

.contentVote-vote { color: inherit; text-decoration: none; line-height: 1; padding: 6px; transition: 0.25s; }

.contentVote-vote:hover { color: inherit; text-decoration: none; }

.contentVote-vote::before { font-family: "Font Awesome 5 Pro"; font-size: inherit; font-style: normal; font-weight: 400; text-rendering: auto; -webkit-font-smoothing: antialiased; }

.contentVote-vote.is-disabled { opacity: 0.2; cursor: not-allowed; }

.contentVote.is-voted .contentVote-vote:not(.is-voted) { opacity: 0.5; }

.contentVote-vote.is-voted { transform: scale(1.75); }

.contentVote-vote.contentVote-vote--up.is-voted { color: rgb(239, 239, 239); }

.contentVote-vote.contentVote-vote--up::before { content: "п„Ҷ"; width: 1.28571em; display: inline-block; text-align: center; }

.contentVote-vote.contentVote-vote--down.is-voted { color: rgb(239, 239, 239); }

.contentVote-vote.contentVote-vote--down::before { content: "п„Ү"; width: 1.28571em; display: inline-block; text-align: center; }

.contentVote-score { direction: ltr; }

