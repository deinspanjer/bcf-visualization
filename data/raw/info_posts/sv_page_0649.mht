.sv-styled-notice { color: rgb(230, 230, 230); background: url("https://forums.sufficientvelocity.com/data/svg/20/1/1777609026/notice_background.svg") right center / auto 110% no-repeat rgb(27, 41, 56); }

.sv-styled-notice.notice--hasImage .notice-content { margin-left: inherit; padding-bottom: 15px; }

.sv-styled-notice.notice--hasImage .notice-image { position: absolute; bottom: 0px; right: 5px; padding: 0px; }

.sv-stop-notice { background-color: rgb(51, 0, 0); color: rgb(230, 230, 230); background-image: url("https://forums.sufficientvelocity.com/data/svg/20/1/1777609026/notice_background.svg"); background-position: right center; background-size: auto 110%; background-repeat: no-repeat; }

.sv-stop-notice .sv-notice-icon, .sv-stop-notice .sv-notice-icon-small { color: rgb(255, 0, 0); }

.sv-warning-notice { background-color: rgb(51, 33, 0); color: rgb(230, 230, 230); background-image: url("https://forums.sufficientvelocity.com/data/svg/20/1/1777609026/notice_background.svg"); background-position: right center; background-size: auto 110%; background-repeat: no-repeat; }

.sv-warning-notice .sv-notice-icon, .sv-warning-notice .sv-notice-icon-small { color: rgb(255, 165, 0); }

.sv-alert-notice { background-color: rgb(51, 43, 0); color: rgb(230, 230, 230); background-image: url("https://forums.sufficientvelocity.com/data/svg/20/1/1777609026/notice_background.svg"); background-position: right center; background-size: auto 110%; background-repeat: no-repeat; }

.sv-alert-notice .sv-notice-icon, .sv-alert-notice .sv-notice-icon-small { color: rgb(255, 215, 0); }

.sv-information-notice { background-color: rgb(12, 32, 39); color: rgb(230, 230, 230); background-image: url("https://forums.sufficientvelocity.com/data/svg/20/1/1777609026/notice_background.svg"); background-position: right center; background-size: auto 110%; background-repeat: no-repeat; }

.sv-information-notice .sv-notice-icon, .sv-information-notice .sv-notice-icon-small { color: rgb(173, 216, 230); }

.sv-large-notice { color: rgb(230, 230, 230); background: url("https://forums.sufficientvelocity.com/data/svg/20/1/1777609026/corner_impact.svg") left bottom / 300px no-repeat, radial-gradient(at 60% 0%, rgba(0, 128, 128, 0), rgba(0, 69, 128, 0.5)) 0% 0% / contain rgb(27, 41, 56); }

.sv-large-notice .notice-content { padding: 0px; display: flex; height: 100%; }

.sv-large-notice .notice-content :last-child { max-width: none; }

.sv-large-notice .notice-dismiss { position: absolute; top: 10px; right: 10px; z-index: 3; }

.sv-large-notice .notice-left { padding: 10px 10px 32px 32px; width: 100%; max-width: 400px; }

.sv-large-notice .notice-buttons { float: right; margin-top: 32px; }

.sv-large-notice .notice-logo { content: url("https://forums.sufficientvelocity.com/data/svg/20/1/1777609026/logo_icon.svg"); float: left; position: relative; left: -16px; width: 64px; height: 64px; margin-top: 10px; margin-bottom: 10px; }

.sv-large-notice .sv-notice-icon, .sv-large-notice .sv-notice-icon-small { position: relative; left: -16px; }

.sv-large-notice .notice-right { width: 100%; background-repeat: no-repeat; background-size: contain; background-position: center center; }

