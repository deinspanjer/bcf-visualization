.alert.is-unread { color: rgb(230, 230, 230); background: rgb(27, 41, 56); }

.alertToggler { padding: 6px; margin-right: -6px; text-decoration: none !important; }

.alert .alertToggler { opacity: 0; }

.alert:hover .alertToggler, .has-touchevents .alertToggler { opacity: 1; }

.alertToggler-icon { font-size: 0.75em; font-weight: 400; }

.is-unread .alertToggler-icon { font-weight: 900; }

.contentVote { position: relative; display: flex; flex-direction: column; align-items: center; min-width: 1.41em; color: rgb(175, 175, 175); font-size: 1.5625rem; }

.contentVote-vote { color: inherit; text-decoration: none; line-height: 1; padding: 6px; transition: 0.25s; }

.contentVote-vote:hover { color: inherit; text-decoration: none; }

.contentVote-vote::before { font-family: "Font Awesome 5 Pro"; font-size: inherit; font-style: normal; font-weight: 400; text-rendering: auto; -webkit-font-smoothing: antialiased; }

.contentVote-vote.is-disabled { opacity: 0.2; cursor: not-allowed; }

.contentVote.is-voted .contentVote-vote:not(.is-voted) { opacity: 0.5; }

.contentVote-vote.is-voted { transform: scale(1.75); }

.contentVote-vote.contentVote-vote--up.is-voted { color: rgb(239, 239, 239); }

.contentVote-vote.contentVote-vote--up::before { content: "’äå"; width: 1.28571em; display: inline-block; text-align: center; }

.contentVote-vote.contentVote-vote--down.is-voted { color: rgb(239, 239, 239); }

.contentVote-vote.contentVote-vote--down::before { content: "’äć"; width: 1.28571em; display: inline-block; text-align: center; }

.contentVote-score { direction: ltr; }

.message .contentVote-score:first-child { padding-top: 6px; }

.contentVote.is-voted .contentVote-score { color: rgb(239, 239, 239); }

.contentVote-description { font-size: 0.8125rem; }

.contentVote.contentVote--small { font-size: 0.75rem; }

.contentVote.contentVote--small .contentVote-description { font-size: 0.625rem; }

.contentVote.contentVote--placeholder .contentVote-score { line-height: 1; }

@media (max-width: 650px) {
  .message .contentVote { flex-direction: row; justify-content: center; }
  .message .contentVote-score { min-width: 1.41em; text-align: center; padding: 0px 6px; }
  .message .contentVote-score:first-child { padding-top: 0px; }
