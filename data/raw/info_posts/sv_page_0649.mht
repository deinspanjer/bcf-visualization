					<div class="bbWrapper"><blockquote data-attributes="member: 42519" data-quote="Koraan" data-source="post: 20541028" class="bbCodeBlock bbCodeBlock--expandable bbCodeBlock--quote js-expandWatch is-expandable">
	
		<div class="bbCodeBlock-title">

			
