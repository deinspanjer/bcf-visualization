@charset "utf-8";

.message + .message, .message.message--bordered { border-top: 1px solid rgb(77, 77, 77); }

.message.is-mod-selected, .block--messages .message.is-mod-selected { background: rgb(51, 73, 94); }

.message.is-mod-selected .message-cell--user, .block--messages .message.is-mod-selected .message-cell--user, .message.is-mod-selected .message-cell--vote, .block--messages .message.is-mod-selected .message-cell--vote { background: rgb(51, 73, 94); }

.message.is-mod-selected .message-userArrow::after, .block--messages .message.is-mod-selected .message-userArrow::after { border-right-color: rgb(51, 73, 94); }

.message-inner { display: flex; }

.message-inner + .message-inner { border-top: 1px solid rgb(77, 77, 77); }

.message-cell { display: block; vertical-align: top; padding: 10px; }

.message--quickReply .message-cell > .formRow:last-child > dd { padding-bottom: 0px; }

.message-cell.message-cell--closer { padding: 6px; }

.message-cell.message-cell--closer.message-cell--user { flex: 0 0 152px; }

.message--simple .message-cell.message-cell--closer.message-cell--user { flex: 0 0 82px; }

.message-cell.message-cell--closer.message-cell--action { flex: 0 0 52px; }

.message-cell.message-cell--user, .message-cell.message-cell--action { position: relative; background: rgb(29, 29, 29); border-right: 1px solid rgb(77, 77, 77); min-width: 0px; }

.message-cell.message-cell--vote { position: relative; background: rgb(29, 29, 29); border-left: 1px solid rgb(77, 77, 77); border-right: 0px; padding-top: 0px; padding-bottom: 0px; }

.message--solution .message-cell.message-cell--vote { background: rgb(218, 243, 216); }

.message-cell.message-cell--vote .solutionIcon { margin-top: 6px; }

.message-cell.message-cell--user { flex: 0 0 160px; }

.message--simple .message-cell.message-cell--user { flex: 0 0 82px; }

.message-cell.message-cell--action { flex: 0 0 60px; }

.message-cell.message-cell--main { flex: 1 1 auto; width: 100%; min-width: 0px; }

.message-cell.message-cell--main.is-editing { padding: 0px; }

.message-cell.message-cell--main .block { margin: 0px; }

.message-cell.message-cell--main .block-container { margin: 0px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; }

.message-cell.message-cell--alert { font-size: 0.6875rem; flex: 1 1 auto; width: 100%; min-width: 0px; color: rgb(224, 224, 224); background: rgb(57, 91, 124); }

.message-cell.message-cell--alert a { color: rgb(239, 239, 239); }

.message-cell.message-cell--extra { flex: 0 0 200px; border-left: 1px solid rgb(77, 77, 77); background: rgb(29, 29, 29); }

.message-cell.message-cell--extra .formRow-explain { margin: 6px 0px 0px; color: rgb(175, 175, 175); font-size: 80%; }

.message-cell.message-cell--extra .formRow-explain a { color: inherit; text-decoration: underline; }

.message-cell.message-cell--header, .message-cell.message-cell--solutionHeader { flex: 1 1 auto; width: 100%; min-width: 0px; padding: 8px 10px; margin: 0px; }

.message-cell.message-cell--header { text-decoration: none; font-size: 0.8125rem; color: rgb(253, 254, 255); font-weight: 900; background: linear-gradient(rgb(71, 113, 152) 0%, rgb(55, 87, 117) 20%, rgb(47, 74, 100) 100%); border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; }

.message-cell.message-cell--header a { color: inherit; text-decoration: none; }

.message-cell.message-cell--header a:hover { text-decoration: underline; }

.message-cell.message-cell--solutionHeader { color: rgb(61, 121, 63); font-size: 0.8125rem; background: rgb(218, 243, 216); border-left: 3px solid rgb(99, 178, 101); }

.message-main { height: 100%; display: flex; flex-direction: column; }

.message-content { flex: 1 1 auto; min-height: 1px; }

.message-footer { margin-top: auto; }

.message-expandWrapper { position: relative; overflow: hidden; }

.message-expandWrapper .message-expandContent { max-height: 250px; overflow: hidden; }

.message-expandWrapper .message-expandContent--small { max-height: 160px; }

.message-expandWrapper.is-expandable .message-expandLink { display: block; }

.message-expandWrapper.is-expanded .message-expandContent { max-height: none; }

.message-expandWrapper.is-expanded .message-expandLink { display: none; }

.message-column { display: flex; flex-direction: column; align-items: center; }

.message-expandLink { display: none; position: absolute; inset: 60% 0px 0px; cursor: pointer; z-index: 100; background: linear-gradient(rgba(39, 39, 39, 0) 0%, rgb(39, 39, 39) 70%); }

.message-expandLink:empty { cursor: auto; background: linear-gradient(rgba(39, 39, 39, 0) 0%, rgb(39, 39, 39) 100%); }

.message-expandLink a { position: absolute; bottom: 10px; left: 0px; right: 0px; text-align: center; font-size: 0.6875rem; color: rgb(239, 239, 239); text-decoration: none; }

.message-microdata { display: none; }

@media (max-width: 650px) {
  .message:not(.message--forceColumns) .message-inner { display: block; }
  .message:not(.message--forceColumns) .message-cell { display: block; }
  .message:not(.message--forceColumns) .message-cell::before, .message:not(.message--forceColumns) .message-cell::after { content: " "; display: table; }
  .message:not(.message--forceColumns) .message-cell::after { clear: both; }
  .message:not(.message--forceColumns) .message-cell.message-cell--user { width: auto; border-right-width: medium; border-right-style: none; border-right-color: currentcolor; border-bottom: 1px solid rgb(77, 77, 77); }
  .message:not(.message--forceColumns) .message-cell.message-cell--vote { width: auto; border-left-width: medium; border-left-style: none; border-left-color: currentcolor; border-top: 1px solid rgb(77, 77, 77); }
  .message:not(.message--forceColumns) .message-cell.message-cell--vote .solutionIcon { margin-top: 0px; }
  .message:not(.message--forceColumns) .message-cell.message-cell--main { padding-left: 10px; }
  .message:not(.message--forceColumns) .message-cell.message-cell--extra { width: auto; border-left-width: medium; border-left-style: none; border-left-color: currentcolor; border-top: 1px solid rgb(77, 77, 77); }
  .message:not(.message--forceColumns) .message-column { flex-direction: row; justify-content: space-evenly; }
  .message--simple:not(.message--forceColumns) .message-cell.message-cell--user, .message--quickReply:not(.message--forceColumns) .message-cell.message-cell--user { display: none; }
}

.message-userArrow { position: absolute; top: 20px; right: -1px; border-width: 10px 10px 10px 0px; border-style: solid; border-color: transparent rgb(77, 77, 77) transparent transparent; border-image: initial; }

.message-userArrow::after { position: absolute; top: -9px; right: -10px; content: ""; border-width: 9px 9px 9px 0px; border-style: solid; border-color: transparent rgb(39, 39, 39) transparent transparent; border-image: initial; }

.message-avatar { text-align: center; }

.message-avatar .avatar { vertical-align: bottom; }

.message-avatar-wrapper { position: relative; display: inline-block; vertical-align: bottom; margin-bottom: 0.5em; }

.message-avatar-wrapper .message-avatar-online { position: absolute; top: 0px; left: 0px; border-width: 7px; border-style: solid; border-color: rgb(127, 185, 0) transparent transparent rgb(127, 185, 0); border-image: initial; border-top-left-radius: 6px; }

.message-avatar-wrapper .avatar { border-radius: 6px; }

.message-name { font-weight: 900; font-size: inherit; text-align: center; margin: 0px; }

.message-userTitle { font-size: 0.625rem; font-weight: normal; text-align: center; margin: 0px; }

.message-userBanner.userBanner { display: block; margin-top: 3px; }

.message-userExtras { margin-top: 3px; font-size: 0.625rem; }

.message--deleted .message-userDetails { display: none; }

.message--deleted .message-avatar .avatar { width: 48px; height: 48px; font-size: 29px; }

@media (max-width: 650px) {
  .message:not(.message--forceColumns) .message-userArrow { inset: auto auto -1px 24px; border-width: 0px 10px 10px; border-style: solid; border-color: transparent transparent rgb(77, 77, 77); border-image: initial; }
  .message:not(.message--forceColumns) .message-userArrow::after { inset: auto auto -10px -9px; border-width: 0px 9px 9px; border-style: solid; border-color: transparent transparent rgb(39, 39, 39); border-image: initial; }
  .message:not(.message--forceColumns).is-mod-selected .message-userArrow::after { border-color: transparent transparent rgb(51, 73, 94); }
  .message:not(.message--forceColumns) .message-user { display: flex; }
  .message:not(.message--forceColumns) .message-avatar { margin-bottom: 0px; }
  .message:not(.message--forceColumns) .message-avatar .avatar { width: 48px; height: 48px; font-size: 29px; }
  .message:not(.message--forceColumns) .message-userDetails { flex: 1 1 0%; min-width: 0px; padding-left: 10px; }
  .message:not(.message--forceColumns) .message-name { text-align: left; }
  .message:not(.message--forceColumns) .message-userBanner.userBanner { display: inline-block; }
  .message:not(.message--forceColumns) .message-userTitle, .message:not(.message--forceColumns) .message-userBanner.userBanner { text-align: left; margin: 0px; }
  .message:not(.message--forceColumns) .message-userExtras > * { display: none; }
  .message:not(.message--forceColumns) .message--deleted .message-userDetails { display: block; }
}

.message-content { position: relative; }

.message-content .js-selectToQuoteEnd { height: 0px; font-size: 0px; overflow: hidden; }

.message--multiQuoteList .message-content { min-height: 80px; max-height: 120px; overflow: hidden; }

.message--multiQuoteList .message-content .message-body { pointer-events: none; }

.message-attribution { color: rgb(175, 175, 175); font-size: 0.625rem; padding-bottom: 3px; border-bottom: 1px solid rgb(62, 62, 62); }

.message-attribution::before, .message-attribution::after { content: " "; display: table; }

.message-attribution::after { clear: both; }

.message-attribution.message-attribution--plain { border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; font-size: inherit; padding-bottom: 0px; }

