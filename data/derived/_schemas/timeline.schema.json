{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bcf-visualization/derived/timeline.schema.json",
  "title": "In-world Timeline",
  "description": "Author-provided pre-story dates merged with Whamodyne's reader-curated in-story timeline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_source", "_attribution", "_count",
    "_first_in_world_date", "_last_in_world_date",
    "_note", "entries"
  ],
  "properties": {
    "_source":              { "type": "string" },
    "_attribution":         { "type": "string" },
    "_count":               { "type": "integer", "minimum": 0 },
    "_first_in_world_date": { "type": ["string", "null"], "format": "date" },
    "_last_in_world_date":  { "type": ["string", "null"], "format": "date" },
    "_note":                { "type": "string" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "in_world_date_iso", "in_world_date_text", "events", "attribution"],
      "properties": {
        "sequence":           { "type": "integer", "minimum": 1 },
        "in_world_date_iso":  { "type": ["string", "null"], "format": "date" },
        "in_world_date_text": { "type": "string" },
        "events":             { "type": "string", "minLength": 1 },
        "attribution":        { "enum": ["author", "Whamodyne"] }
      }
    }
  }
}
