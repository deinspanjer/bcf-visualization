{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bcf-visualization/derived/chapter_last_edited.schema.json",
  "title": "Chapter Last-Edited Timestamps",
  "description": "Per-chapter 'Last edited:' timestamps from the SV thread, scraped from the FicHub EPUB. Date-only (SV strips the time). Used as a fact column in chapter_facts.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_source", "_count", "_with_timestamp",
    "_without_timestamp_count", "_without_timestamp_chapters",
    "chapters"
  ],
  "properties": {
    "_source":                       { "type": "string" },
    "_count":                        { "type": "integer", "minimum": 0 },
    "_with_timestamp":               { "type": "integer", "minimum": 0 },
    "_without_timestamp_count":      { "type": "integer", "minimum": 0 },
    "_without_timestamp_chapters": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" }
    },
    "chapters": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" }
    }
  },
  "$defs": {
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chapter_num", "full_title", "last_edited_at",
        "last_edited_known", "edited_lag_days"
      ],
      "properties": {
        "chapter_num":      { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" },
        "full_title":       { "type": "string", "minLength": 1 },
        "last_edited_at": {
          "anyOf": [
            { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            { "type": "null" }
          ]
        },
        "last_edited_known": { "type": "boolean" },
        "edited_lag_days": {
          "anyOf": [
            { "type": "integer" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
