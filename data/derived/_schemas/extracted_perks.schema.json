{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bcf-visualization/derived/extracted_perks.schema.json",
  "title": "Extracted Perks",
  "description": "Per-chapter perk listings parsed from the 'Jumpchain abilities this chapter:' footer of each EPUB chapter. Independent of the curator catalog — useful for filling catalog gaps with author-canonical names, sources, and costs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["_source", "_count", "_total_perks", "_note", "chapters"],
  "properties": {
    "_source":      { "type": "string" },
    "_count":       { "type": "integer", "minimum": 0 },
    "_total_perks": { "type": "integer", "minimum": 0 },
    "_note":        { "type": "string" },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chapter_num", "chapter_full_title", "epub_href", "perks"],
        "properties": {
          "chapter_num":        { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" },
          "chapter_full_title": { "type": "string", "minLength": 1 },
          "epub_href":          { "type": "string", "minLength": 1 },
          "perks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "source", "cost_text", "cost", "free", "description"],
              "properties": {
                "name":        { "type": "string", "minLength": 1 },
                "source":      { "type": "string", "minLength": 1 },
                "cost_text":   { "type": "string", "minLength": 1 },
                "cost":        { "type": "integer", "minimum": 0 },
                "free":        { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
