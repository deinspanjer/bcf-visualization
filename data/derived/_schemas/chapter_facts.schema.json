{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bcf-visualization/derived/chapter_facts.schema.json",
  "title": "Chapter Facts (visualization backbone)",
  "description": "Per-chapter fact table — one row per published chapter, with sections and rolls as nested 1:N dimensions. Backbone for the planned scrubber/DAW-style visualization. Shadow periods are top-level because regime-3 recovery shadows can cross chapter boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "_source", "_method", "_count", "_grain", "_deferred",
    "shadow_periods", "in_world_timeline", "chapters"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "_source": { "type": "string" },
    "_method": { "type": "string" },
    "_count":  { "type": "integer", "minimum": 0 },
    "_grain":  { "type": "string" },
    "_deferred": { "type": "array", "items": { "type": "string" } },
    "shadow_periods": {
      "type": "array",
      "items": { "$ref": "#/$defs/shadow_period" }
    },
    "in_world_timeline": {
      "description": "Embedded canonical timeline merged from all sources (xlsx + wiki + TUI annotations + manual). Mirrors the entry shape from data/derived/timeline.json. The visualization loads chapter_facts.json and reads this directly — there is no separate fetch.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "_sources_used", "_count",
        "_first_in_world_date", "_last_in_world_date", "entries"
      ],
      "properties": {
        "_sources_used": {
          "type": "array",
          "items": { "enum": ["xlsx", "wiki", "tui", "manual"] },
          "uniqueItems": true
        },
        "_count":               { "type": "integer", "minimum": 0 },
        "_first_in_world_date": { "type": ["string", "null"], "format": "date" },
        "_last_in_world_date":  { "type": ["string", "null"], "format": "date" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeline_entry" }
        }
      }
    },
    "chapters": {
      "type": "array",
      "items": { "$ref": "#/$defs/chapter" }
    }
  },
  "$defs": {
    "shadow_period": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_perk_id", "trigger_perk_name", "trigger_perk_cost",
        "trigger_chapter_num", "trigger_word_position_epub",
        "shadow_word_length", "shadow_end_word_position_epub",
        "shadow_end_chapter_num"
      ],
      "properties": {
        "trigger_perk_id":               { "type": ["string", "null"] },
        "trigger_perk_name":             { "type": "string", "minLength": 1 },
        "trigger_perk_cost":             { "type": "integer", "enum": [600, 800] },
        "trigger_chapter_num":           { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" },
        "trigger_word_position_epub": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "shadow_word_length":            { "type": "integer", "minimum": 0 },
        "shadow_end_word_position_epub": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "shadow_end_chapter_num":        { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" }
      }
    },
    "timeline_entry": {
      "description": "Mirror of one entry from data/derived/timeline.json. Kept structurally identical so the canonical schema is the source of truth.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "in_world_date_iso", "time_of_day", "event_text",
        "source", "source_ref", "chapter_num", "tags"
      ],
      "properties": {
        "id":                { "type": "string", "pattern": "^(xlsx|wiki|tui|manual):[A-Za-z0-9_:.\\-]+$" },
        "in_world_date_iso": { "type": "string", "format": "date" },
        "time_of_day":       { "enum": [null, "morning", "afternoon", "evening", "night"] },
        "event_text":        { "type": "string", "minLength": 1 },
        "source":            { "enum": ["xlsx", "wiki", "tui", "manual"] },
        "source_ref":        { "type": "string" },
        "chapter_num":       { "type": ["string", "null"] },
        "tags": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        }
      }
    },
    "in_world": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_date", "start_time_of_day", "end_date",
        "end_time_of_day", "spans_days", "confidence", "evidence"
      ],
      "properties": {
        "start_date":         { "type": ["string", "null"] },
        "start_time_of_day":  { "type": ["string", "null"], "enum": [null, "morning", "afternoon", "evening", "night"] },
        "end_date":           { "type": ["string", "null"] },
        "end_time_of_day":    { "type": ["string", "null"], "enum": [null, "morning", "afternoon", "evening", "night"] },
        "spans_days":         { "type": ["integer", "null"], "minimum": 0 },
        "confidence":         { "enum": ["high", "medium", "low", "stub"] },
        "evidence":           { "type": ["string", "null"] }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_index", "header", "marker_kind", "pov_character",
        "word_count", "cp_earning_word_count", "counts_for_cp",
        "classification", "classification_confidence",
        "structural_markers",
        "char_offset_start_in_chapter", "char_offset_end_in_chapter",
        "in_world_start_time_of_day", "in_world_end_time_of_day"
      ],
      "properties": {
        "section_index":   { "type": "integer", "minimum": 0 },
        "header":          { "type": ["string", "null"] },
        "marker_kind": {
          "enum": [
            "main_implicit", "main_titled", "preamble", "addendum",
            "interlude", "abilities", "author_note", "other"
          ]
        },
        "pov_character":              { "type": ["string", "null"] },
        "word_count":                 { "type": "integer", "minimum": 0 },
        "cp_earning_word_count":      { "type": "integer", "minimum": 0 },
        "counts_for_cp":              { "type": "boolean" },
        "span_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/eligibility_span_override" }
        },
        "classification":             { "type": ["string", "null"] },
        "classification_confidence":  { "type": ["string", "null"] },
        "structural_markers":         { "type": "array", "items": { "type": "string" } },
        "char_offset_start_in_chapter": { "type": "integer", "minimum": 0 },
        "char_offset_end_in_chapter":   { "type": "integer", "minimum": 0 },
        "in_world_start_time_of_day": { "type": ["string", "null"], "enum": [null, "morning", "afternoon", "evening", "night"] },
        "in_world_end_time_of_day":   { "type": ["string", "null"], "enum": [null, "morning", "afternoon", "evening", "night"] }
      }
    },
    "eligibility_span_override": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "word_offset_start", "word_offset_end", "counts_for_cp",
        "reason_code", "note", "excerpt"
      ],
      "properties": {
        "word_offset_start": { "type": "integer", "minimum": 0 },
        "word_offset_end":   { "type": "integer", "minimum": 0 },
        "counts_for_cp":     { "type": "boolean" },
        "reason_code":       { "type": "string", "minLength": 1 },
        "note":              { "type": ["string", "null"] },
        "excerpt":           { "type": "string" }
      }
    },
    "roll": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roll_number", "section_index", "outcome", "constellation",
        "mechanical_chapter_num", "mechanical_word_position",
        "mechanical_cumulative_word_offset",
        "mention_chapter_num", "mention_word_position",
        "display_position_policy", "display_chapter_num",
        "display_word_position", "display_cumulative_word_offset",
        "source_chapter_num", "source_roll_index",
        "source_word_position", "source_cumulative_word_offset",
        "visible_chapter_nums",
        "purchased_perk_id", "purchased_perks", "purchased_perk_cost_total",
        "purchased_perk_jump", "free_perks",
        "word_position", "cumulative_word_offset",
        "predicted_word_position_epub", "display_word_position_epub",
        "predicted_char_offset_in_chapter",
        "anchor_char_offset_in_chapter", "evidence_kind",
        "evidence_quotes",
        "available_cp", "banked_cp_after_roll",
        "rolled_perk_name", "rolled_perk_cost", "miss_cost_estimate",
        "roll_sequence_in_chapter", "rolls_in_chapter",
        "fact_source", "source_kind"
      ],
      "properties": {
        "roll_number": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "section_index": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "outcome":                      { "enum": ["hit", "miss", "unknown"] },
        "constellation":                { "type": ["string", "null"] },
        "mechanical_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mechanical_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "mechanical_cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "mention_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mention_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "display_position_policy": {
          "enum": [
            "mention", "mechanical", "section_start",
            "source_marker", "section_end"
          ]
        },
        "display_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "display_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "display_cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "source_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "source_roll_index": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "source_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "source_cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "visible_chapter_nums": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d+(\\.\\d+)?$"
          },
          "uniqueItems": true
        },
        "purchased_perk_id":            { "type": ["string", "null"] },
        "purchased_perks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "cost"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "cost": { "type": "integer", "minimum": 0 },
              "free": { "type": "boolean" }
            }
          }
        },
        "purchased_perk_cost_total": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "purchased_perk_jump":          { "type": ["string", "null"] },
        "free_perks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "jump", "constellation"],
            "properties": {
              "id":            { "type": ["string", "null"] },
              "name":          { "type": "string", "minLength": 1 },
              "jump":          { "type": "string", "minLength": 1 },
              "constellation": { "type": ["string", "null"] }
            }
          }
        },
        "word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "predicted_word_position_epub": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "display_word_position_epub": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "predicted_char_offset_in_chapter": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "anchor_char_offset_in_chapter": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "evidence_kind": {
          "enum": [
            "direct", "general_only", "forward_ref", "silent",
            "untracked_acquisition", "curator_log", "interpolated",
            "synthetic"
          ]
        },
        "evidence_quotes": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_quote" }
        },
        "available_cp": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "banked_cp_after_roll": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "rolled_perk_name":          { "type": ["string", "null"] },
        "rolled_perk_cost": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "miss_cost_estimate": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "roll_sequence_in_chapter": { "type": "integer", "minimum": 1 },
        "rolls_in_chapter":        { "type": "integer", "minimum": 1 },
        "fact_source":             { "enum": ["curator_rolls", "roll_outcomes"] },
        "source_kind":             { "enum": ["trigger", "roll", "miss", "interpolated"] }
      }
    },
    "skipped_predicted_roll": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_index", "roll_number",
        "mechanical_chapter_num", "mechanical_word_position",
        "mechanical_cumulative_word_offset",
        "predicted_word_position_epub", "reason"
      ],
      "properties": {
        "slot_index": { "type": "integer", "minimum": 1 },
        "roll_number": { "type": "integer", "minimum": 1 },
        "mechanical_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mechanical_word_position": { "type": "integer", "minimum": 0 },
        "mechanical_cumulative_word_offset": {
          "type": "integer",
          "minimum": 0
        },
        "predicted_word_position_epub": { "type": "integer", "minimum": 0 },
        "reason": { "enum": ["skipped_to_align_narrative"] }
      }
    },
    "evidence_quote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "mention_chapter_num", "mention_word_position"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "mention_chapter_num": {
          "type": ["string", "null"],
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mention_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        }
      }
    },
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chapter_num", "full_title", "sort_key", "point_calculation_regime",
        "epub_href",
        "published_at", "published_source",
        "last_edited_at", "last_edited_source",
        "edited_lag_days",
        "in_world",
        "total_word_count", "cp_earning_word_count",
        "rolls_count", "hits_count", "misses_count", "unknowns_count",
        "perks_gained", "paid_perks_gained", "free_perks_gained",
        "cumulative_words_through_chapter", "cumulative_cp_earning_words",
        "cumulative_perks_through_chapter",
        "banked_cp_at_start", "banked_cp_at_end",
        "model_validation", "constellation_progress",
        "pov_characters", "structural_markers",
        "sections", "skipped_predicted_rolls", "rolls"
      ],
      "properties": {
        "chapter_num":     { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" },
        "full_title":      { "type": "string", "minLength": 1 },
        "sort_key":        { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 },
        "point_calculation_regime": { "type": "integer", "enum": [1, 2, 3] },
        "epub_href":       { "type": "string" },

        "published_at":      { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "published_source":  { "type": "string", "enum": ["manual", "ao3", "epub"] },
        "last_edited_at":    { "anyOf": [{ "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }, { "type": "null" }] },
        "last_edited_source":{ "anyOf": [{ "type": "string", "enum": ["manual", "ao3", "epub"] }, { "type": "null" }] },
        "edited_lag_days":   { "anyOf": [{ "type": "integer" }, { "type": "null" }] },

        "in_world": { "$ref": "#/$defs/in_world" },

        "total_word_count":           { "type": "integer", "minimum": 0 },
        "cp_earning_word_count":      { "type": "integer", "minimum": 0 },
        "rolls_count":                { "type": "integer", "minimum": 0 },
        "hits_count":                 { "type": "integer", "minimum": 0 },
        "misses_count":               { "type": "integer", "minimum": 0 },
        "unknowns_count":             { "type": "integer", "minimum": 0 },
        "perks_gained":               { "type": "integer", "minimum": 0 },
        "paid_perks_gained":          { "type": "integer", "minimum": 0 },
        "free_perks_gained":          { "type": "integer", "minimum": 0 },

        "cumulative_words_through_chapter": { "type": "integer", "minimum": 0 },
        "cumulative_cp_earning_words":      { "type": "integer", "minimum": 0 },
        "cumulative_perks_through_chapter": { "type": "integer", "minimum": 0 },
        "banked_cp_at_start": { "type": ["integer", "null"] },
        "banked_cp_at_end":   { "type": ["integer", "null"] },
        "model_validation": { "$ref": "#/$defs/model_validation" },
        "constellation_progress": {
          "type": "array",
          "items": { "$ref": "#/$defs/constellation_progress" }
        },

        "pov_characters":     { "type": "array", "items": { "type": "string" } },
        "structural_markers": { "type": "array", "items": { "type": "string" } },

        "sections": { "type": "array", "items": { "$ref": "#/$defs/section" } },
        "skipped_predicted_rolls": {
          "type": "array",
          "items": { "$ref": "#/$defs/skipped_predicted_roll" }
        },
        "rolls":    { "type": "array", "items": { "$ref": "#/$defs/roll" } }
      }
    },
    "constellation_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name", "count", "total", "discovered", "discovered_pct",
        "complete", "visible"
      ],
      "properties": {
        "name": {
          "enum": [
            "Toolkits", "Knowledge", "Vehicles", "Time", "Crafting",
            "Clothing", "Magic", "Quality", "Size",
            "Resources and Durability", "Magitech", "Alchemy",
            "Capstone", "Personal Reality"
          ]
        },
        "count":          { "type": "integer", "minimum": 0 },
        "total":          { "type": "integer", "minimum": 0 },
        "discovered":     { "type": "integer", "minimum": 0 },
        "discovered_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "complete":       { "type": "boolean" },
        "visible":        { "type": "boolean" }
      }
    },
    "model_validation_issue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "severity", "message"],
      "properties": {
        "code":     { "type": "string", "minLength": 1 },
        "severity": { "enum": ["error", "warning", "info"] },
        "message":  { "type": "string", "minLength": 1 },
        "resolved": { "type": "boolean" },
        "resolution_reason_code": { "type": ["string", "null"] },
        "resolution_note": { "type": ["string", "null"] }
      }
    },
    "model_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "current_discrepancy", "prior_discrepancy",
        "raw_current_discrepancy", "first_discrepancy_chapter_num", "source_priority",
        "predicted_roll_count", "required_paid_roll_count",
        "known_attempt_count", "paid_roll_capacity_ok",
        "known_attempt_capacity_ok", "cost_schedule_ok",
        "synthetic_slot_count", "resolved_issue_codes", "issues"
      ],
      "properties": {
        "status": { "enum": ["ok", "discrepancy", "unknown"] },
        "current_discrepancy": { "type": "boolean" },
        "raw_current_discrepancy": { "type": "boolean" },
        "prior_discrepancy": { "type": "boolean" },
        "first_discrepancy_chapter_num": {
          "type": ["string", "null"],
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "source_priority": {
          "enum": ["vetted_curated", "curator_log", "derived_perk_list", "none"]
        },
        "predicted_roll_count": { "type": "integer", "minimum": 0 },
        "required_paid_roll_count": { "type": "integer", "minimum": 0 },
        "known_attempt_count": { "type": "integer", "minimum": 0 },
        "paid_roll_capacity_ok": { "type": "boolean" },
        "known_attempt_capacity_ok": { "type": "boolean" },
        "cost_schedule_ok": { "type": "boolean" },
        "synthetic_slot_count": { "type": "integer", "minimum": 0 },
        "resolved_issue_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/model_validation_issue" }
        }
      }
    }
  }
}
