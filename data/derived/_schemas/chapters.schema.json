{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bcf-visualization/derived/chapters.schema.json",
  "title": "Chapters",
  "description": "Per-chapter structural metadata derived from the EPUB navigation document and chapter HTML. `total_word_count` is the raw chapter token count (headers, author notes, perk footers, non-MC POV sections all included) — NOT the count CP arithmetic runs on. CP-eligible word counts live in chapter_facts.json:cp_earning_word_count.",
  "type": "object",
  "additionalProperties": false,
  "required": ["_source", "_count", "chapters"],
  "properties": {
    "_source": { "type": "string" },
    "_count":  { "type": "integer", "minimum": 0 },
    "chapters": {
      "type": "array",
      "items": { "$ref": "#/$defs/chapter" }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chapter_num", "sort_key", "ordinal", "title", "full_title",
        "epub_href", "total_word_count"
      ],
      "properties": {
        "chapter_num":  { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" },
        "sort_key": {
          "type": "array",
          "prefixItems": [
            { "type": "integer", "minimum": 1 },
            { "type": "integer", "minimum": 0 }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "ordinal":          { "type": "integer", "minimum": 1 },
        "title":            { "type": "string", "minLength": 1 },
        "full_title":       { "type": "string", "minLength": 1 },
        "epub_href":        { "type": "string", "pattern": "^chap_\\d+\\.xhtml$" },
        "total_word_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
