{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bcf-visualization/derived/roll_facts.schema.json",
  "title": "Canonical roll facts",
  "description": "Single derived roll-attempt stream consumed by chapter_facts. Curator roll logs win where present; interpolated roll_outcomes rows are provenance-marked fallback only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "_source", "_method", "_caveat", "_counts", "rolls"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "_source": { "type": "string" },
    "_method": { "type": "string" },
    "_caveat": { "type": "string" },
    "_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rolls_emitted", "curator_rows", "interpolated_rows",
        "hits", "misses", "triggers", "free_perks"
      ],
      "properties": {
        "rolls_emitted": { "type": "integer", "minimum": 0 },
        "curator_rows": { "type": "integer", "minimum": 0 },
        "interpolated_rows": { "type": "integer", "minimum": 0 },
        "hits": { "type": "integer", "minimum": 0 },
        "misses": { "type": "integer", "minimum": 0 },
        "triggers": { "type": "integer", "minimum": 0 },
        "free_perks": { "type": "integer", "minimum": 0 }
      }
    },
    "rolls": {
      "type": "array",
      "items": { "$ref": "#/$defs/roll" }
    }
  },
  "$defs": {
    "free_perk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "jump", "constellation"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "name": { "type": "string", "minLength": 1 },
        "jump": { "type": "string", "minLength": 1 },
        "constellation": { "type": ["string", "null"] },
        "survey_designation": { "$ref": "#/$defs/survey_designation" }
      }
    },
    "roll": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roll_key",
        "predicted_ordinal", "predicted_label",
        "source_ordinal", "source_label",
        "roll_ordinal", "roll_label",
        "chapter_ordinal", "chapter_label",
        "association_source",
        "chapter_num", "predicted_chapter_num",
        "mechanical_chapter_num", "mechanical_word_position",
        "mechanical_cumulative_word_offset",
        "mention_chapter_num", "mention_word_position",
        "display_position_policy", "display_chapter_num",
        "display_word_position", "display_cumulative_word_offset",
        "source_chapter_num", "source_chapter_ordinal", "source_roll_label",
        "source_word_position", "source_cumulative_word_offset",
        "visible_chapter_nums",
        "chapter_attribution_disagreement", "source", "source_kind",
        "outcome", "constellation", "constellation_revealed",
        "available_cp", "banked_cp_after_roll",
        "purchased_perks", "purchased_perk_cost_total",
        "purchased_perk_id", "purchased_perk_jump", "free_perks",
        "rolled_perk_name", "rolled_perk_instance",
        "rolled_perk_cost", "miss_cost_estimate",
        "predicted_word_position_epub", "predicted_char_offset_in_chapter",
        "anchor_char_offset_in_chapter", "evidence_kind",
        "evidence_quotes", "raw", "source_row_index", "roll_sequence_in_chapter",
        "rolls_in_chapter", "slot_source",
        "word_position", "cumulative_word_offset",
        "epub_word_offset_predicted", "epub_word_offset_curated"
      ],
      "properties": {
        "roll_key": { "type": "string", "minLength": 1 },
        "predicted_ordinal": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "predicted_label": { "type": ["string", "null"], "pattern": "^P\\d+$" },
        "source_ordinal": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "source_label": { "type": ["string", "null"], "pattern": "^S\\d+$" },
        "roll_ordinal": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "roll_label": { "type": ["string", "null"], "pattern": "^R\\d+$" },
        "chapter_ordinal": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "chapter_label": { "type": ["string", "null"], "pattern": "^C\\d+$" },
        "association_source": { "enum": ["auto", "curated", "none"] },
        "chapter_num": { "type": "string", "pattern": "^\\d+(\\.\\d+)?$" },
        "predicted_chapter_num": {
          "type": ["string", "null"],
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mechanical_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mechanical_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "mechanical_cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "mention_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mention_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "display_position_policy": {
          "enum": [
            "mention", "mechanical", "section_start",
            "source_marker", "section_end"
          ]
        },
        "display_chapter_num": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "display_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "display_cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "source_chapter_num": {
          "type": ["string", "null"],
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "source_chapter_ordinal": {
          "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
        },
        "source_roll_label": { "type": ["string", "null"] },
        "source_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "source_cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "visible_chapter_nums": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d+(\\.\\d+)?$"
          },
          "uniqueItems": true
        },
        "chapter_attribution_disagreement": { "type": "boolean" },
        "source": { "enum": ["curator_rolls", "roll_outcomes"] },
        "source_kind": { "enum": ["trigger", "roll", "miss", "interpolated"] },
        "curator_added": { "type": "boolean" },
        "outcome": { "enum": ["hit", "miss"] },
        "constellation": { "type": ["string", "null"] },
        "constellation_revealed": { "type": "boolean" },
        "available_cp": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "banked_cp_after_roll": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "purchased_perk_id": { "type": ["string", "null"] },
        "purchased_perks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "cost", "free"],
            "properties": {
              "name":      { "type": "string", "minLength": 1 },
              "instance":  { "type": ["string", "null"] },
              "id":        { "type": ["string", "null"] },
              "cost":      { "type": "integer", "minimum": 0 },
              "cost_unit": { "type": ["string", "null"] },
              "jump":      { "type": ["string", "null"] },
              "free":      { "type": "boolean" },
              "survey_designation": { "$ref": "#/$defs/survey_designation" }
            }
          }
        },
        "purchased_perk_cost_total": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "purchased_perk_jump": { "type": ["string", "null"] },
        "free_perks": {
          "type": "array",
          "items": { "$ref": "#/$defs/free_perk" }
        },
        "rolled_perk_name":     { "type": ["string", "null"] },
        "rolled_perk_instance": { "type": ["string", "null"] },
        "rolled_perk_cost": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "miss_cost_estimate": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "predicted_word_position_epub": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "predicted_char_offset_in_chapter": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "anchor_char_offset_in_chapter": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "evidence_kind": {
          "enum": [
            "direct", "general_only", "forward_ref", "silent",
            "curator_log", "interpolated", "synthetic"
          ]
        },
        "raw": { "type": ["string", "null"] },
        "evidence_quotes": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_quote" }
        },
        "source_row_index": { "type": "integer", "minimum": 0 },
        "roll_sequence_in_chapter": { "type": "integer", "minimum": 1 },
        "rolls_in_chapter": { "type": "integer", "minimum": 1 },
        "slot_source": {
          "enum": [
            "curator", "curator+override", "solver", "interpolated", "override"
          ]
        },
        "word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "cumulative_word_offset": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "epub_word_offset_predicted": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "epub_word_offset_curated": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        }
      }
    },
    "survey_designation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code", "order_obtained", "constellation_code",
        "constellation_order", "cost_code", "bundle_order", "source"
      ],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "order_obtained": { "type": "integer", "minimum": 1 },
        "constellation_code": { "type": "string", "minLength": 1 },
        "constellation_order": { "type": "integer", "minimum": 1 },
        "cost_code": { "type": "string", "minLength": 1 },
        "bundle_order": { "type": ["string", "null"] },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_quote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "mention_chapter_num", "mention_word_position"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "mention_chapter_num": {
          "type": ["string", "null"],
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "mention_word_position": {
          "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "cp_ledger_checkpoint": {
          "$ref": "#/$defs/cp_ledger_checkpoint"
        }
      }
    },
    "cp_ledger_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "banked_cp_after_roll"],
      "properties": {
        "kind": { "const": "post_roll_banked_cp_reset" },
        "banked_cp_after_roll": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
